   "source": [
    "import customtkinter as ctk\n",
    "import psycopg2\n",
    "from tkinter import messagebox\n",
    "from PIL import Image, ImageDraw\n",
    "\n",
    "\n",
    "# 🎨 COLOR SYSTEM\n",
    "\n",
    "COLOR_SIDEBAR_DARK = \"#4B1E0F\"\n",
    "COLOR_WORKSPACE_BG = \"#F3EBDD\"\n",
    "COLOR_ACCENT_ORANGE = \"#B85C2E\"\n",
    "COLOR_CARD_BG = \"#EADFC9\"\n",
    "COLOR_TEXT_DARK = \"#3E2A1F\"\n",
    "\n",
    "ctk.set_appearance_mode(\"light\")\n",
    "\n",
    "\n",
    "# 🔌 DATABASE CONNECTION\n",
    "\n",
    "def connect():\n",
    "\n",
    "    return psycopg2.connect(\n",
    "        dbname=\"safepath\",\n",
    "        user=\"postgres\",\n",
    "        password=\"cos101\",\n",
    "        host=\"localhost\",\n",
    "        port=\"5432\"\n",
    "    )\n",
    "\n",
    "\n",
    "# 👥 CREATE USERS TABLE IF NOT EXISTS\n",
    "\n",
    "def create_users_table():\n",
    "\n",
    "    conn = connect()\n",
    "    cur = conn.cursor()\n",
    "\n",
    "    cur.execute(\"\"\"\n",
    "\n",
    "        CREATE TABLE IF NOT EXISTS users (\n",
    "\n",
    "            id SERIAL PRIMARY KEY,\n",
    "            username VARCHAR(100) UNIQUE NOT NULL,\n",
    "            password VARCHAR(100) NOT NULL\n",
    "\n",
    "        )\n",
    "\n",
    "    \"\"\")\n",
    "\n",
    "    conn.commit()\n",
    "\n",
    "    cur.close()\n",
    "    conn.close()\n",
    "\n",
    "# CREATE TABLE ON STARTUP\n",
    "create_users_table()\n",
    "\n",
    "\n",
    "# 🔐 AUTHENTICATION LOGIC\n",
    "\n",
    "def verify_or_register_user(username, password, mode=\"signin\"):\n",
    "\n",
    "    if not username or not password:\n",
    "        return False, \"Please fill in all fields.\"\n",
    "\n",
    "    conn = connect()\n",
    "    cur = conn.cursor()\n",
    "\n",
    "    try:\n",
    "\n",
    "        # CHECK IF USER EXISTS\n",
    "        cur.execute(\n",
    "            \"SELECT password FROM users WHERE username = %s\",\n",
    "            (username,)\n",
    "        )\n",
    "\n",
    "        row = cur.fetchone()\n",
    "\n",
    "        \n",
    "        # LOGIN MODE\n",
    "       \n",
    "        if mode == \"signin\":\n",
    "\n",
    "            if row is None:\n",
    "\n",
    "                return False, \"UserNotFound\"\n",
    "\n",
    "            elif row[0] == password:\n",
    "\n",
    "                return True, \"Login successful!\"\n",
    "\n",
    "            else:\n",
    "\n",
    "                return False, \"Incorrect password.\"\n",
    "\n",
    "       \n",
    "        # SIGNUP MODE\n",
    "        \n",
    "        elif mode == \"signup\":\n",
    "\n",
    "            if row is not None:\n",
    "\n",
    "                return False, \"Username already exists.\"\n",
    "\n",
    "            else:\n",
    "\n",
    "                cur.execute(\n",
    "                    \"\"\"\n",
    "                    INSERT INTO users (username, password)\n",
    "                    VALUES (%s, %s)\n",
    "                    \"\"\",\n",
    "                    (username, password)\n",
    "                )\n",
    "\n",
    "                conn.commit()\n",
    "\n",
    "                return True, \"Account created successfully!\"\n",
    "\n",
    "    except Exception as e:\n",
    "\n",
    "        return False, str(e)\n",
    "\n",
    "    finally:\n",
    "\n",
    "        cur.close()\n",
    "        conn.close()\n",
    "\n",
    "\n",
    "#  BACKGROUND GRADIENT\n",
    "\n",
    "def create_gradient_image(width, height, color1, color2):\n",
    "\n",
    "    base_img = Image.new(\"RGB\", (width, height), color1)\n",
    "\n",
    "    draw = ImageDraw.Draw(base_img)\n",
    "\n",
    "    r1, g1, b1 = int(color1[1:3], 16), int(color1[3:5], 16), int(color1[5:7], 16)\n",
    "    r2, g2, b2 = int(color2[1:3], 16), int(color2[3:5], 16), int(color2[5:7], 16)\n",
    "\n",
    "    for y in range(height):\n",
    "\n",
    "        mix = y / height\n",
    "\n",
    "        r = int(r1 + (r2 - r1) * mix)\n",
    "        g = int(g1 + (g2 - g1) * mix)\n",
    "        b = int(b1 + (b2 - b1) * mix)\n",
    "\n",
    "        draw.line([(0, y), (width, y)], fill=(r, g, b))\n",
    "\n",
    "    return ctk.CTkImage(light_image=base_img, size=(width, height))\n",
    "\n",
    "=\n",
    "#  MAIN AUTH WINDOW\n",
    "\n",
    "class SafePathAuthWindow(ctk.CTk):\n",
    "\n",
    "    def __init__(self):\n",
    "\n",
    "        super().__init__()\n",
    "\n",
    "        self.geometry(\"1000x700\")\n",
    "        self.title(\"SafePath Portal\")\n",
    "        self.resizable(False, False)\n",
    "\n",
    "        self.current_mode = \"signin\"\n",
    "\n",
    "        # BACKGROUND\n",
    "        self.bg_label = ctk.CTkLabel(self, text=\"\")\n",
    "        self.bg_label.place(x=0, y=0, relwidth=1, relheight=1)\n",
    "\n",
    "        self.bind(\"<Configure>\", self.render_background)\n",
    "\n",
    "        # BUILD UI\n",
    "        self.build_auth_card()\n",
    "\n",
    "   \n",
    "    def render_background(self, event=None):\n",
    "\n",
    "        gradient_img = create_gradient_image(\n",
    "            1000,\n",
    "            700,\n",
    "            COLOR_ACCENT_ORANGE,\n",
    "            COLOR_SIDEBAR_DARK\n",
    "        )\n",
    "\n",
    "        self.bg_label.configure(image=gradient_img)\n",
    "        self.bg_label.image = gradient_img\n",
    "\n",
    "    \n",
    "    def build_auth_card(self):\n",
    "\n",
    "        self.card = ctk.CTkFrame(\n",
    "            self,\n",
    "            width=420,\n",
    "            height=480,\n",
    "            fg_color=COLOR_CARD_BG,\n",
    "            corner_radius=24,\n",
    "            border_width=1,\n",
    "            border_color=\"#D9C2A3\"\n",
    "        )\n",
    "\n",
    "        self.card.place(relx=0.5, rely=0.5, anchor=\"center\")\n",
    "        self.card.pack_propagate(False)\n",
    "\n",
    "        # TITLE\n",
    "        self.title_lbl = ctk.CTkLabel(\n",
    "            self.card,\n",
    "            text=\"Login\",\n",
    "            font=(\"Georgia\", 32, \"bold\"),\n",
    "            text_color=COLOR_SIDEBAR_DARK\n",
    "        )\n",
    "\n",
    "        self.title_lbl.pack(pady=(45, 30))\n",
    "\n",
    "        # USERNAME\n",
    "        self.user_entry = ctk.CTkEntry(\n",
    "            self.card,\n",
    "            placeholder_text=\"Username\",\n",
    "            width=320,\n",
    "            height=45,\n",
    "            corner_radius=10,\n",
    "            fg_color=COLOR_WORKSPACE_BG,\n",
    "            text_color=COLOR_TEXT_DARK\n",
    "        )\n",
    "\n",
    "        self.user_entry.pack(pady=12)\n",
    "\n",
    "        # PASSWORD\n",
    "        self.pass_entry = ctk.CTkEntry(\n",
    "            self.card,\n",
    "            placeholder_text=\"Password\",\n",
    "            show=\"•\",\n",
    "            width=320,\n",
    "            height=45,\n",
    "            corner_radius=10,\n",
    "            fg_color=COLOR_WORKSPACE_BG,\n",
    "            text_color=COLOR_TEXT_DARK\n",
    "        )\n",
    "\n",
    "        self.pass_entry.pack(pady=12)\n",
    "\n",
    "        # ACTION BUTTON\n",
    "        self.action_btn = ctk.CTkButton(\n",
    "            self.card,\n",
    "            text=\"Login\",\n",
    "            command=self.execute_auth,\n",
    "            fg_color=COLOR_SIDEBAR_DARK,\n",
    "            hover_color=\"#33140A\",\n",
    "            text_color=\"white\",\n",
    "            width=320,\n",
    "            height=48,\n",
    "            corner_radius=12,\n",
    "            font=(\"Arial\", 16, \"bold\")\n",
    "        )\n",
    "\n",
    "        self.action_btn.pack(pady=(25, 15))\n",
    "\n",
    "        # TOGGLE LABEL\n",
    "        self.toggle_lbl = ctk.CTkLabel(\n",
    "            self.card,\n",
    "            text=\"Don't have an account? Sign up here\",\n",
    "            font=(\"Arial\", 12, \"underline\"),\n",
    "            text_color=COLOR_TEXT_DARK,\n",
    "            cursor=\"hand2\"\n",
    "        )\n",
    "\n",
    "        self.toggle_lbl.pack(pady=5)\n",
    "\n",
    "        self.toggle_lbl.bind(\n",
    "            \"<Button-1>\",\n",
    "            lambda e: self.switch_mode()\n",
    "        )\n",
    "\n",
    "    \n",
    "    def switch_mode(self):\n",
    "\n",
    "        self.current_mode = (\n",
    "            \"signup\"\n",
    "            if self.current_mode == \"signin\"\n",
    "            else \"signin\"\n",
    "        )\n",
    "\n",
    "        if self.current_mode == \"signin\":\n",
    "\n",
    "            self.title_lbl.configure(text=\"Login\")\n",
    "\n",
    "            self.action_btn.configure(\n",
    "                text=\"Login\",\n",
    "                fg_color=COLOR_SIDEBAR_DARK\n",
    "            )\n",
    "\n",
    "            self.toggle_lbl.configure(\n",
    "                text=\"Don't have an account? Sign up here\"\n",
    "            )\n",
    "\n",
    "        else:\n",
    "\n",
    "            self.title_lbl.configure(text=\"Create Account\")\n",
    "\n",
    "            self.action_btn.configure(\n",
    "                text=\"Register Account\",\n",
    "                fg_color=COLOR_ACCENT_ORANGE\n",
    "            )\n",
    "\n",
    "            self.toggle_lbl.configure(\n",
    "                text=\"Already have an account? Sign in here\"\n",
    "            )\n",
    "\n",
    " \n",
    "    def execute_auth(self):\n",
    "\n",
    "        username = self.user_entry.get().strip()\n",
    "        password = self.pass_entry.get().strip()\n",
    "\n",
    "        success, message = verify_or_register_user(\n",
    "            username,\n",
    "            password,\n",
    "            mode=self.current_mode\n",
    "        )\n",
    "\n",
    "        if success:\n",
    "\n",
    "            messagebox.showinfo(\n",
    "                \"SafePath\",\n",
    "                message\n",
    "            )\n",
    "\n",
    "            self.destroy()\n",
    "\n",
    "            \n",
    "            # OPEN DASHBOARD HERE LATER\n",
    "           \n",
    "            print(\"Launch dashboard here.\")\n",
    "\n",
    "        else:\n",
    "\n",
    "            if message == \"UserNotFound\":\n",
    "\n",
    "                response = messagebox.askyesno(\n",
    "                    \"User Not Found\",\n",
    "                    f\"No account found for '{username}'.\\nCreate account?\"\n",
    "                )\n",
    "\n",
    "                if response:\n",
    "\n",
    "                    self.switch_mode()\n",
    "\n",
    "            else:\n",
    "\n",
    "                messagebox.showerror(\n",
    "                    \"Authentication Error\",\n",
    "                    message\n",
    "                )\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "\n",
    "    app = SafePathAuthWindow()\n",
    "    app.mainloop()"
   ]
  },
